# Google Gemini API Key (obtenha em https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_api_key_here

# Modelo Gemini a usar
GEMINI_MODEL=gemini-2.0-flash

# Caminho para o currículo base .tex
RESUME_TEX_PATH=../curriculo.tex

# Habilitar autenticação do Firebase (true/false)
AUTH_ENABLED=false
